    35 A3A7 C0 88			cpy	#cio_error.eof	; EOF
    36 A3A9 F0 08			beq	??ce1
    37 A3AB 98				tya
    38 A3AC C0 80			cpy	#cio_error.break ; BREAK key
    39 A3AE F0 11			beq	break1
    40 A3B0 4C CB 04			jmp	error
    41
