    23 					.enum rom	;Equates only used in ROM mode
    24
    25 				; Cartridge type that determines the bank ordering and bank identifiers according to
    26 				; http://atari800.cvs.sourceforge.net/viewvc/atari800/atari800/DOC/cart.txt
    27 				;
    28 				;+---------------------------------------------------------------------------+
    29 				;| Type 15: OSS one chip 16 KB cartridge                                     |
    30 				;+---------------------------------------------------------------------------+
    31 				;
    32 				; There are two types of OSS 16KB cartridges; this is the later, simpler one.
    33 				; Used by BASIC XL 1.03, Action! 3.6, MAC/65 1.1 and BASIC XE 4.1 (and possibly
    34 				; also by later versions of the above software).
    35 				; It consists of one 16 KB ROM chip.
    36 				; The cartridge occupies 8 KB of address space between $A000 and $BFFF. Its
    37 				; memory is divided into 4 banks, 4 KB each. Bank number 0 (the first one) is
    38 				; always mapped to $B000-$BFFF. Bank in $A000-$AFFF is selected by an access to
    39 				; $D500-$D5FF. Only bits 0 and 3 of address are significant:
    40 				; - A3=0, A0=0 - selects bank 1, bank id $00
    41 				; - A3=0, A0=1 - selects bank 3, bank id $01
    42 				; - A3=1, A0=0 - disables cartridge, bank id $08, enables computer's memory in address space between $A000 and $BFFF
    43 				; - A3=1, A0=1 - selects bank 2, bank id $09 
    44
    45 				; bank switching defs
    46 				;---------------------
    47 = B000			ml	=	$b000
    48 = A000			el	=	$a000
    49 = A000			ll	=	$a000
    50 = A000			cl	=	$a000
    51
    52 = D500			bank	=	$d500
    53 = 0009			bankmsk	=	%1001			; Only bit 3 and 0 are relevant
    54
    55 = 0003			ebank	=	3			; Editor bank, was 1 in original source
    56 = 0000			lbank	=	0			; Library bank
    57 = 0009			cbank	=	9			; Compiler bank
    58
    59 = 0A00			serial	=	$0a00			; ACTION 3.6 serial number word at $A2FA
    60 									; Normally $00 in the source and set before burning the ROM.
    61 					.ende
    62
    63 					.macro m_end_switched_bank
    64 				bank_used_end
    65 					.align	rom.:1+$0fff,$00	; Fill with empty bytes instead of $ff.
    66 				bank_end
    67 					.byte	rom.:2 & rom.bankmsk	; Bank identifier at end of bank.
    68 					.print "Ending switched bank :1/:2: " , bank_used_end, " - ", bank_end, "(", bank_end-bank_used_end+1, " bytes free)"
    69 					.endm
