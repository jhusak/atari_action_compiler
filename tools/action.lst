    73 				; PROC PrintF(STRING f, CARD a1, a2, a3, a4, a5)
    74 				; outputs a1-a5 to default device
    75 				; using format f.  Any non '%' char
    76 				; in f is output directly.  '%' char
    77 				; is interpreted as follows:
    78 				;    %S - output next arg as string
    79 				;    %I - output next arg as signed number
    80 				;    %U - output next arg as unsigned number
    81 				;    %C - output next arg as CHAR
    82 				;    %H - output next arg as HEX
    83 				;    %% - output '%' char
    84 				;    %E - output EOL
    85 				; any other char after % is treated
    86 				; the same as %U.
    87 				;
    88 A3CC			prtf	.proc		; PROC PrintF(STRING f, CARD a1, a2, a3, a4, a5)
    89 A3CC 85 C0			sta	addr
    90 A3CE 86 C1			stx	addr+1
    91 A3D0 8C F0 05			sty	temps
    92 A3D3 A0 00			ldy	#0
    93 A3D5 B1 C0			lda	(addr),y
    94 A3D7 85 C2			sta	token
    95 A3D9 E6 C2			inc	token
    96 A3DB A2 0D			ldx	#13
    97 A3DD B5 A2		??pf1	lda	args+2,x
    98 A3DF 9D F0 05			sta	temps,x
    99 A3E2 CA				dex
   100 A3E3 D0 F8			bne	??pf1
   101 A3E5 86 8B			stx	lsttoken
   102 A3E7 86 8A			stx	op
   103 A3E9 E6 8A		??pf2	inc	op
   104 A3EB A4 8A			ldy	op
   105 A3ED C4 C2			cpy	token
   106 A3EF B0 DA			bcs	break1.??pfe	; return
   107 A3F1 B1 C0			lda	(addr),y
   108 A3F3 C9 25			cmp	#'%'
   109 A3F5 D0 0F			bne	??pf3
   110 A3F7 E6 8A			inc	op
   111 A3F9 C8				iny
   112 A3FA B1 C0			lda	(addr),y
   113 A3FC C9 25			cmp	#'%'
   114 A3FE F0 06			beq	??pf3
   115 A400 C9 45			cmp	#'E'
   116 A402 D0 08			bne	??pf4
   117 A404 A9 9B			lda	#eol
   118 A406 20 CE A4		??pf3	jsr	put
   119 A409 4C E9 A3			jmp	??pf2
   120 				;
   121 A40C A4 8B		??pf4	ldy	lsttoken
   122 A40E E6 8B			inc	lsttoken
   123 A410 E6 8B			inc	lsttoken
   124 A412 85 A0			sta	args
   125 A414 B9 F0 05			lda	temps,y
   126 A417 BE F1 05			ldx	temps+1,y
   127 A41A A4 A0			ldy	args
   128 A41C C0 43			cpy	#'C'
   129 A41E F0 E6			beq	??pf3
   130 A420 C0 53			cpy	#'S'
   131 A422 D0 06			bne	??pf5
   132 A424 20 7F A4			jsr	prt
   133 A427 4C E9 A3			jmp	??pf2
   134 A42A C0 49		??pf5	cpy	#'I'
   135 A42C D0 06			bne	??pf6
   136 A42E 20 12 A5			jsr	prti
   137 A431 4C E9 A3			jmp	??pf2
   138 A434 C0 48		??pf6	cpy	#'H'
   139 A436 D0 06			bne	??pf7
   140 A438 20 C2 B8			jsr	mainbnk.prth
   141 A43B 4C E9 A3			jmp	??pf2
   142 A43E 20 E6 A4		??pf7	jsr	prtc
   143 A441 4C E9 A3			jmp	??pf2
   144 					.endp
