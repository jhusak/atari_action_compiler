   135 B363				.enum	errors		; Text from reference manual
   136 = 0000			memer	=	0		; Out of system memory
   137 = 0001			strer	=	1		; Missing quote in a string
   138 = 0002			dfner	=	2		; Nested DEFINEs
   139 = 0003			gster	=	3		; Global variable symbol table full
   140 = 0004			lster	=	4		; Local variable symbol table full
   141 = 0005			seter	=	5		; SET directive syntax error
   142 = 0006			dcler	=	6		; Declaration error
   143 = 0007			arger	=	7		; Invalid argument list
   144 = 0008			varer	=	8		; Variable not declared
   145 = 0009			conster	=	9		; Not a constant
   146 = 000A			asser	=	10		; Illegal assignment
   147 = 000B			ender	=	11		; Unknown error
   148 = 000C			thener	=	12		; Missing THEN
   149 = 000D			fier	=	13		; Missing FI
   150 = 000E			cder	=	14		; Out of code space
   151 = 000F			doer	=	15		; Missing DO
   152 = 0010			toer	=	16		; Missing TO
   153 = 0011			exper	=	17		; Bad expression
   154 = 0012			parer	=	18		; Unmatched parentheses
   155 = 0013			oder	=	19		; Missing OD
   156 = 0014			alcer	=	20		; Cannot allocate memory
   157 = 0015			arrer	=	21		; Illegal array reference
   158 = 0016			fileer	=	22		; Input file too large
   159 = 0017			cnder	=	23		; Illegal conditional expression
   160 = 0018			forer	=	24		; Illegal FOR statement syntax
   161 = 0019			exiter	=	25		; Illegal EXIT
   162 = 001A			nster	=	26		; Nesting too deep
   163 = 001B			typer	=	27		; Illegal TYPE syntax
   164 = 001C			reter	=	28		; Illegal RETURN
   165 = 003D			stspcer	=	61 		; Out of symbol table space
   166 = 0080			brker	=	$80		; BREAK key pressed
   167 					.ende
   168
   169 					.if feature_error_texts = 1
   170
   171 					.proc error_texts
   172
   173 					.proc get_error_text	
   174 					x1	= arg2
   175 					p1	= arg0
   176
   177 					sta	x1
   178 					mwy	#texts p1
   179 				loop	ldy	#0
   180 					lda	(p1),y
   181 					cmp	x1
   182 					beq	found
   183 					cmp	#texts.not_found
   184 					beq	not_found
   185 					iny
   186 					clc
   187 					lda	(p1),y
   188 					adc	#1+1		;Skip error code and length byte
   189 					adc	p1
   190 					sta	p1
   191 					scc
   192 					inc	p1+1
   193 					bne	loop		; Unconditional branch
   194
   195 				not_found
   196 					mwa	#texts.unknown p1
   197
   198 				found	inw	p1		; Skip error code
   199 					rts
   200 					.endp
   201
   202
   203 					.local texts
   204
   205 					not_found = $ff
   206
   207 					.macro m_error_text
   208 					.byte errors.:1
   209 					m_string :2
   210 					.endm
   211
   212 					m_error_text memer,	'Out of system memory'
