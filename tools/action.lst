    43 A3B4 4A				lsr
    44 A3B5 4A				lsr
    45 A3B6 4A				lsr
    46 A3B7 4A				lsr
    47 A3B8 AA				tax
    48 A3B9 98				tya
    49 A3BA 9D C0 05			sta	eof,x
    50 A3BD			??ce2
    51 					.if	.def ramzap
    52 					.if	ramzap
    53 A3BD DE 95 A3			dec	chkerr-$10,x
    54 					.else
    55 					nop
    56 					nop
    57 					nop
    58 					.endif
    59 					.endif
