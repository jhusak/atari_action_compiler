   197 					.macro m_align		; Fills with empty bytes instead of $ff
   198 				align_used_end
   199 					.align	:1,$00
   200 				align_end
   201 					.print "Aligning " , align_used_end, " - ", align_end, "(", align_end-align_used_end+1, " bytes free)"
   202 					.endm
   203
   204 					.macro m_assert_next	; Asserts the a fall-though ends up in the right location
   205 					.if :0 <> 1
   206 					.error "Wrong number of arguments"
   207 					.endif
   208 					.if * <> :1
   209 					.error "Fall-though to next label broken. Next label at ", *, " must be ", ":1" 
   210 					.endif
   211 					.endm
