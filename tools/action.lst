    28 				; PROC ChkErr=*(BYTE result, block, errCode)
    29 				; checks for error return from CIO
    30 				; Sets EOF(block) to true on error
    31 				; does not call Error if EOF error ($88)
    32 				; see Hardware manual for CIO details
    33 A3A5			chkerr	.proc			; PROC ChkErr=*(BYTE result, block, errCode)
