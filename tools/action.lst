  1438 				;	Expression processing
  1439 				;=====================================
  1440
  1441 				; <exp> ??:= <exp> XOR <equiv> | <equiv>
  1442 				; <equiv> ??:= <equiv> OR <logical prod> | <logical prod>
  1443 				; <logical prod> ??:= <logical prod> AND <relation> | <relation>
  1444 				; <relation> ??:= <relation> <rel op> <add exp> | <add exp>
  1445 				; <add exp> ??:= <add exp> <add op> <mult exp> | <mult exp>
  1446 				; <mult exp> ??:= <mult exp> <mult op> <factor> | <factor>
  1447 				; <factor> ??:= <unary op> <primary> | <primary>
  1448 				; <primary> ??:= <constant> | <var> | ( <exp> )
  1449
  1450 				; <rel op> ??:= # | = | <high  | < | high  | <= | high =
  1451 				; <add op> ??:= + | -
  1452 				; <mult op> ??:= * | / | LSH | RSH | REM
  1453 				; <unary op> ??:= @ | -
