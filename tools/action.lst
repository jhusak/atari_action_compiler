   603 				; PROC Note(BYTE dev, CARD POINTER sector, BYTE POINTER offset)
   604 				; returns disk sector and offset in that
   605 				; sector of next byte to be read or
   606 				; written to IOCB dev
   607 				; example:  Note(1, @sect, @pos)
   608 				; see Hardware manual
