   153 AEF3				.proc get_yes_or_no
   154 AEF3 F0 04			beq	??yn1			;Determine character for current flag value
   155 AEF5 A0 59			ldy	#'Y'
   156 AEF7 D0 02			bne	??yn2
   157 AEF9 A0 4E		??yn1	ldy	#'N'
   158 AEFB 8C 91 05		??yn2	sty	tempbuf+1
   159 AEFE A0 01			ldy	#1
   160 AF00 20 9F AF			jsr	gettmpbuf
   161 AF03 AD 91 05			lda	tempbuf+1
   162 AF06 AC 90 05			ldy	tempbuf
   163 AF09 D0 07			bne	??yn5
   164 AF0B C9 1B			cmp	#character.escape
   165 AF0D D0 02			bne	??yn4
   166 AF0F 68			exit	pla	
   167 AF10 68				pla	
   168 AF11 60			??yn4	rts
   169
   170 AF12 09 20		??yn5	ora	#'a'-'A'		;Convert to lower case
   171 AF14 C9 79			cmp	#'y'
   172 AF16 60				rts	
   173 					.end
