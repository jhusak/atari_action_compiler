MODULE››BYTE pass=[0]›BYTE fail=[0]››DEFINE STRING="BYTE ARRAY"›  STRING s(32)›  BYTE b›  CARD c›  INT i›  BYTE R›››PROC Assert(STRING name INT act,exp)›  IF act=exp THEN›    pass==+1›    PrintF("[OK] %S%E",name)›  ELSE›    fail==+1›    PrintF("[FAIL] %S%E",name)›  FI›RETURN››PROC Main()›  PrintE("AUTO TEST")››  StrB(123,s)›  R=SCompare(s,"123")›  Assert("StrB",R,0)›  StrC(54321,s)›  R=SCompare(s,"54321")›  Assert("StrC",R,0)››  StrI(-1234,s)›  R=SCompare(s,"-1234")›  Assert("StrI",R,0)››  b=ValB("123")›  Assert("ValB",b,123)››  c=ValC("54321")›  Assert("ValC",c,54321)››  i=ValI("-1234")›  Assert("ValI",i,-1234)››  PrintE("")›  PrintE("PrintF visual test:")›  PrintF("S=%S I=%I U=%U C=%C H=%H %% %E",›         "ABC",-10,100,'A,$1234)››  PrintE("")›  PrintE("PrintB/C/I visual test:")›  PrintB(255)›  Put(' )›  PrintC(65535)›  Put(' )›  PrintI(-32768)›  PutE()››  PrintE("")›  PrintF("PASS=%U FAIL=%U%E",pass,fail)››DO OD›RETURN›