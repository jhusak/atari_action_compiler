MODULE››DEFINE STRING="BYTE ARRAY"››PROC Main()›  BYTE dev=[1]›  BYTE ch›  BYTE pos›  CARD sec››  STRING s(80)››  PrintE("I/O TEST")››  Open(dev,"D:TESTTXT.TXT",8,0)››  PrintDE(dev,"FIRST LINE")›  PrintDE(dev,"SECOND LINE")››  Note(dev,@sec,@pos)››  PrintF("NOTE SEC=%U POS=%U%E",sec,pos)››  Close(dev)››  Open(dev,"D:TESTTXT.TXT",4,0)››  Point(dev,0,11)››  s(0)=79›  InputSD(dev,s)››  PrintF("READ: %S%E",s)››  Close(dev)››  PrintE("")›  PrintE("Keyboard test")›  PrintE("Press one key")››  ch=GetD(0)››  PrintF("KEY=%U CHAR=%C%E",ch,ch)››  PrintE("")›  PrintE("InputS test")››  s(0)=79›  InputS(s)››  PrintF("TEXT=%S%E",s)››  PrintE("")›  PrintE("PutD test")››  Put('>)›  Put(' )›  Put('O)›  Put('K)›  PutE()››  PrintE("")›  PrintE("Optional XIO test skipped")››  DO OD›RETURN›