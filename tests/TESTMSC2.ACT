MODULE››BYTE ARRAY Buf1(256)›BYTE ARRAY Buf2(256)››;BYTE FUNC GetD(CHAR ARRAY s BYTE i)› ; RETURN(s(i)-'0)›››PROC WaitKey()›  PrintE("Press RETURN...")›  DO UNTIL GetD(1)=155 OD›RETURN››PROC TestRand()›  BYTE i,r››  PrintE("=== Rand ===")››  FOR i=1 TO 10›  DO›    r=Rand(100)›    PrintB(r)›    Put(32)›  OD››  PutE()›RETURN››PROC TestSound()›  BYTE i,j››  PrintE("=== Sound ===")››  FOR j=0 TO 24 ›  DO›  FOR i=0 TO 240 ›  DO›    Sound(1,i,10,8)›  OD›  OD››  SndRst()››  PrintE("You should hear tones.")›RETURN››PROC TestControllers()›  BYTE S›  PrintE("=== Joystick/Paddle ===")››  PrintF("Stick(0)  = ")›  S=Stick(0)›  PrintBE(S)››  PrintF("PTrig(0)  = ")›  S=PTrig(0)›  PrintBE(S)››  PrintF("Paddle(0) = ")›  S=Paddle(0)›  PrintBE(S)››  PrintE("Move controls and rerun.")›RETURN››PROC TestPeekPoke()›  BYTE b›  CARD c››  PrintE("=== Peek/Poke ===")››  Poke($0600,$55)›  b=Peek($0600)››  PrintF("BYTE  = ")›  PrintBE(b)››  PokeC($0602,$1234)›  c=PeekC($0602)››  PrintF("CARD  = ")›  PrintCE(c)››RETURN››PROC TestZero()›  BYTE i,ok››  PrintE("=== Zero ===")››  SetBlock(Buf1,100,$AA)›  Zero(Buf1,100)››  ok=1››  FOR i=0 TO 99›  DO›    IF Buf1(i)#0 THEN›      ok=0›    FI›  OD››  IF ok THEN›    PrintE("OK")›  ELSE›    PrintE("FAIL")›  FI›RETURN››PROC TestSetBlock()›  BYTE i,ok››  PrintE("=== SetBlock ===")››  SetBlock(Buf1,100,$5A)››  ok=1››  FOR i=0 TO 99›  DO›    IF Buf1(i)#$5A THEN›      ok=0›    FI›  OD››  IF ok THEN›    PrintE("OK")›  ELSE›    PrintE("FAIL")›  FI›RETURN››PROC TestMoveBlock()›  BYTE i,ok››  PrintE("=== MoveBlock ===")››  FOR i=0 TO 99›  DO›    Buf1(i)=i›    Buf2(i)=0›  OD››  MoveBlock(Buf2,Buf1,100)››  ok=1››  FOR i=0 TO 99›  DO›    IF Buf2(i)#Buf1(i) THEN›      ok=0›    FI›  OD››  IF ok THEN›    PrintE("OK")›  ELSE›    PrintE("FAIL")›  FI›RETURN››PROC TestBreak()›  PrintE("=== Break ===")›  PrintE("Next call should terminate program.")›  PrintE("Comment out if unwanted.")››  Break()››  PrintE("ERROR: Break returned!")›RETURN››PROC Main()››  TestRand()››  PrintE("")›  TestPeekPoke()››  PrintE("")›  TestZero()››  PrintE("")›  TestSetBlock()››  PrintE("")›  TestMoveBlock()››  PrintE("")›  TestSound()››  PrintE("")›  TestControllers()››  ; odkomentuj tylko gdy chcesz sprawdziÄ‡ Break›  ; TestBreak()››  PrintE("")›  PrintE("Tests finished.")›  DO OD›RETURN›