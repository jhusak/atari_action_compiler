MODULE›DEFINE STRING="BYTE ARRAY"››BYTE FUNC GetD(CHAR ARRAY s BYTE i)›  RETURN(s(i)-'0)›››PROC PrintCmp(STRING a STRING b)›  INT r››  r=SCompare(a,b)››  Print("""")›  Print(a)›  PrintF(""" vs """)›  Print(b)›  Print("""")›  PrintF(" => ")››  IF r=0 THEN›    PrintE("EQ")›  ELSEIF r<0 THEN›    PrintE("LT")›  ELSE›    PrintE("GT")›  FI›RETURN››PROC Main()›  STRING src(40)›  STRING dst(40)››  SCOPY(src,"ATARI 8BIT")››  PrintE("=== SCompare ===")››  PrintCmp("ABC","ABC")›  PrintCmp("ABC","ABD")›  PrintCmp("ABD","ABC")›  PrintCmp("","")›  PrintCmp("A","")››  PrintE("")›  PrintE("=== SCopy ===")››  SCopy(dst,src)››  Print("SRC = ")›  PrintE(src)››  Print("DST = ")›  PrintE(dst)››  PrintE("")›  PrintE("=== SCopyS ===")››  SCopyS(dst,src,0,4)››  Print("SRC = ")›  PrintE(src)››  Print("DST = ")›  PrintE(dst)››  SCopyS(dst,src,6,9)››  Print("DST2 = ")›  PrintE(dst)››  PrintE("")›  PrintE("=== SAssign ===")››  SAssign(dst,src,0,4)››  Print("DST = ")›  PrintE(dst)››  SAssign(dst,src,6,9)››  Print("DST2 = ")›  PrintE(dst)››  PrintE("")›  PrintE("KONIEC TESTOW")›  DO OD›RETURN›