MODULE››PROC RUN()›byte g›CARD I›BYTE R›POKE($6A,$A0)››for g=8 to 15 step 7 do›GRAPHICS(g+16)›POKE(765,1)›FOR I=0 TO 159 STEP 10 DO›R=RAND(3)+1›POKE(765,R)        ›PLOT(I,10)›DRAWTO(159-I,191)›OD›SetColor(3,15,15);›SetColor(2,10,10);›SetColor(1,6,6);›Poke(765,1)›Fill(0,0)››Poke(765,2)›Position(150,0)›Fill(140,191)››R=Locate(150,80)›poke(765,r)›Position(10,20)›Fill(80,140)››R=Locate(10,80)›poke(765,r)›Position(100,20)›Fill(140,140)››OD›DO OD››RETURN›